{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "server/**/*",
    "client/src/**/*",
    "client/vite.config.ts",
    "tests/**/*",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
